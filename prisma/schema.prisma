generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Parent {
  id    String @id @default(auto()) @map("_id") @db.ObjectId
  name  String
  email String @unique
  phone String
  users User[]
}

model User { 
  id       String  @id @default(auto()) @map("_id") @db.ObjectId
  email    String  @unique
  name     String
  age      String
  parentId String? @db.ObjectId
  parent   Parent? @relation(fields: [parentId], references: [id], onDelete: Cascade)
} 
